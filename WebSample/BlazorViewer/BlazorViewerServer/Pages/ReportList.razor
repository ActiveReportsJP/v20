
<div class="main-nav navbar">
    <div id="list-heading">レポートの選択</div>
    @if (ReportsList != null)
    {
        <ul id="reportsList" class="nav navbar-nav">
            @foreach (var report in ReportsList)
            {
                var reportName = report.Name;
                <li class="reportList_item @(CurrentReport.Name == reportName ? "active" : "" )">
                    <span @onclick="()=>
                        {
                            OnClickCallback.InvokeAsync(report);
                        }">@reportName</span>
                    @if (report.HasSnapshot)
                    {
                        <input type="checkbox" checked="@report.UseSnapshot" title="最新のスナップショットを開く" @onclick:stopPropagation="true" @onchange="()=>
                        {
                            report.UseSnapshot = !report.UseSnapshot;
                            OnClickCallback.InvokeAsync(report);
                        }" />
                    }
                </li>
            }
        </ul>
    }
</div>
@code {
    [Parameter]
    public List<BlazorViewerServer.Data.ReportDescriptor> ReportsList { get; set; }

    [Parameter]
    public BlazorViewerServer.Data.ReportDescriptor CurrentReport { get; set; }

    [Parameter]
    public EventCallback<BlazorViewerServer.Data.ReportDescriptor> OnClickCallback { get; set; }
}
