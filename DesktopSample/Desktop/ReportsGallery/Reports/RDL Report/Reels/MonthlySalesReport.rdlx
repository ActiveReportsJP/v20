	<ReportParameters>
		<ReportParameter Name="Date">
			<DataType>DateTime</DataType>
			<Prompt>月を選択してください。</Prompt>
			<ValidValues>
				<DataSetReference>
					<DataSetName>MonthYear</DataSetName>
					<LabelField>Label</LabelField>
					<ValueField>MonthYear</ValueField>
				</DataSetReference>
			</ValidValues>
			<DefaultValue>
				<DataSetReference>
					<DataSetName>MonthYear</DataSetName>
					<LabelField>MonthYear</LabelField>
					<ValueField>MonthYear</ValueField>
				</DataSetReference>
			</DefaultValue>
		</ReportParameter>
		<ReportParameter Name="RegionID">
			<DataType>Integer</DataType>
			<Prompt>地位</Prompt>
			<ValidValues>
				<DataSetReference>
					<DataSetName>RegionsDataSet</DataSetName>
					<LabelField>Region</LabelField>
					<ValueField>RegionID</ValueField>
				</DataSetReference>
			</ValidValues>
			<DefaultValue>
				<Values>
					<Value>1</Value>
				</Values>
			</DefaultValue>
		</ReportParameter>
	</ReportParameters>
	<DataSources>
		<DataSource Name="Reels">
			<ConnectionProperties>
				<ConnectString>Data Source=..\\..\\..\\..\\..\\..\\..\\Data\\Reels.db</ConnectString>
				<DataProvider>SQLITE</DataProvider>
			</ConnectionProperties>
		</DataSource>
	</DataSources>
	<DataSets>
		<DataSet Name="MonthYear">
			<Fields>
				<Field Name="MonthYear">
					<DataField>MonthYear</DataField>
				</Field>
				<Field Name="Month">
					<DataField>Month</DataField>
				</Field>
				<Field Name="Year">
					<DataField>Year</DataField>
				</Field>
				<Field Name="Label">
					<DataField>Label</DataField>
				</Field>
			</Fields>
			<Query>
				<CommandText>SELECT DISTINCT
date(strftime('%Y-%m-01', Sale.SaleDate)) AS MonthYear,
strftime('%m', Sale.SaleDate) AS Month,
strftime('%Y', SaleDate) AS Year,
strftime('%m %Y', SaleDate) As Label
FROM Sale
ORDER BY Year ASC, Month ASC</CommandText>
				<DataSourceName>Reels</DataSourceName>
			</Query>
		</DataSet>
		<DataSet Name="SalesData">
			<Fields>
				<Field Name="RegionID">
					<DataField>RegionID</DataField>
				</Field>
				<Field Name="Region">
					<DataField>Region</DataField>
				</Field>
				<Field Name="DistrictID">
					<DataField>DistrictID</DataField>
				</Field>
				<Field Name="District">
					<DataField>District</DataField>
				</Field>
				<Field Name="SaleDate">
					<DataField>SaleDate</DataField>
				</Field>
				<Field Name="Quantity">
					<DataField>Quantity</DataField>
				</Field>
				<Field Name="TotalAmount">
					<DataField>TotalAmount</DataField>
				</Field>
				<Field Name="Profit">
					<DataField>Profit</DataField>
				</Field>
			</Fields>
			<Query>
				<CommandText>SELECT Regions.RegionID,
       Regions.Region,
       Districts.DistrictID,
       Districts.District,
       Sale.SaleDate,
       Sum(SaleDetails.Quantity) AS Quantity,
       Sum(SaleDetails.Quantity * (SaleDetails.Price * (1 - Discount) ) ) AS TotalAmount,
       Sum(SaleDetails.Quantity * ( (SaleDetails.Price * (1 - Discount) - Product.StorePrice) ) ) AS Profit
  FROM Regions
  JOIN Districts ON Regions.RegionID = Districts.Region
  JOIN Store ON Districts.DistrictID = Store.DistrictID
  JOIN Sale ON Store.StoreID = Sale.Store
  JOIN SaleDetails ON Sale.SalesID = SaleDetails.SaleID
  JOIN Product ON Product.ProductID = SaleDetails.ProductID
 WHERE (Regions.RegionID = @RegionID) AND
       ( (strftime('%m', Sale.SaleDate) = strftime('%m', @Date1) ) AND
         (strftime('%Y', Sale.SaleDate) = strftime('%Y', @Date2) ) )
 GROUP BY Regions.RegionID,
          Regions.Region,
          Districts.DistrictID,
          Districts.District,
          Sale.SaleDate</CommandText>
				<DataSourceName>Reels</DataSourceName>
				<QueryParameters>
					<QueryParameter Name="@RegionID">
						<Value>=Parameters!RegionID.Value</Value>
					</QueryParameter>
					<QueryParameter Name="@Date1">
						<Value>=Parameters!Date.Value</Value>
					</QueryParameter>
					<QueryParameter Name="@Date2">
						<Value>=Parameters!Date.Value</Value>
					</QueryParameter>
				</QueryParameters>
			</Query>
		</DataSet>
		<DataSet Name="RegionsDataSet">
			<Fields>
				<Field Name="RegionID">
					<DataField>RegionID</DataField>
				</Field>
				<Field Name="Region">
					<DataField>Region</DataField>
				</Field>
			</Fields>
			<Query>
				<CommandText>SELECT RegionID, Region FROM Regions WHERE RegionID &gt; 0 ORDER BY Region ASC</CommandText>
				<DataSourceName>Reels</DataSourceName>
			</Query>
		</DataSet>
	</DataSets>
	<CustomProperties>
		<CustomProperty>
			<Name>Theme</Name>
			<Value>Reels.rdlx-theme</Value>
		</CustomProperty>
	</CustomProperties>
	<ReportThemes>
		<ThemeUri>Reels.rdlx-theme</ThemeUri>
	</ReportThemes>
</Report>