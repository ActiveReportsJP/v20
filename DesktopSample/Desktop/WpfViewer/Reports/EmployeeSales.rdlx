	<DataSources>
		<DataSource Name="NWind">
			<ConnectionProperties>
				<ConnectString>data source=..\\..\\..\\..\\..\\..\\..\\Data\\NWIND.db;</ConnectString>
				<DataProvider>SQLITE</DataProvider>
			</ConnectionProperties>
		</DataSource>
	</DataSources>
	<DataSets>
		<DataSet Name="Sales">
			<Fields>
				<Field Name="EmployeeName">
					<DataField>EmployeeName</DataField>
				</Field>
				<Field Name="Sales">
					<DataField>Sales</DataField>
				</Field>
			</Fields>
			<Query>
				<CommandText>SELECT LastName || ', ' || FirstName AS EmployeeName, Sum([UnitPrice]*[Quantity]) AS Sales FROM (Employees INNER JOIN Orders ON Employees.EmployeeID = Orders.EmployeeID) INNER JOIN order_details ON Orders.OrderID = order_details.OrderID GROUP BY LastName || ', ' || FirstName</CommandText>
				<DataSourceName>NWind</DataSourceName>
			</Query>
		</DataSet>
	</DataSets>
</Report>