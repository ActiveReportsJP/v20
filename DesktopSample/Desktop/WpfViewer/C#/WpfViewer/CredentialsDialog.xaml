<Window x:Class="ActiveReports.Samples.WPFViewer.CredentialsDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	WindowStyle="ToolWindow" ResizeMode="NoResize"
	MinHeight="250" MinWidth="510" MaxHeight="250" MaxWidth="510" WindowStartupLocation="CenterOwner">
	<Grid>
		<StackPanel Margin="10">
			<TextBlock x:Name="txtPrompt" Margin="0 10"/>
			<StackPanel Orientation="Horizontal">
				<TextBlock x:Name="lblUser" Text="User:" MinWidth="60" VerticalAlignment="Center" Margin="10 10" HorizontalAlignment="Left"/>
				<TextBox x:Name="txtUser" VerticalAlignment="Center" Margin="5" MinWidth="380"/>
			</StackPanel>
			<StackPanel Orientation="Horizontal">
				<TextBlock x:Name="lblPassword" Text="Password:" MinWidth="60" VerticalAlignment="Center" Margin="10 0"/>
				<PasswordBox x:Name="txtPassword" VerticalAlignment="Center" Margin="5" MinWidth="380"/>
			</StackPanel>
			<StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="25 50 25 10">
				<Button x:Name="btnOk" Content="OK" MinWidth="75" Margin="0 0 10 0"/>
				<Button x:Name="btnCancel" Content="Cancel" MinWidth="75"/>
			</StackPanel>
		</StackPanel>
	</Grid>
</Window>
