<?xml version="1.0" encoding="utf-8" ?>
<Configuration>
  <ActiveReportsConfig>
    <DataProviders>
            <add name="SQLITE"
             type="System.Data.SQLite.SQLiteFactory, System.Data.SQLite"
             displayName="SQLite Provider" />
            <add name="MYSQL"
             type="MySqlConnector.MySqlConnectorFactory, MySqlConnector"
             displayName="MySQL Provider" />
            <add name="POSTGRESQL"
             type="Npgsql.NpgsqlFactory, Npgsql"
             displayName="PostgreSQL Provider" />
            <add name="EXCEL"
             type="GrapeCity.ActiveReports.Core.DataProviders.Excel.ExcelDataProviderFactory, MESCIUS.ActiveReports.Core.DataProviders.Excel"
             displayName="Excel Provider" />
      </DataProviders>
      <MapTileProviders>
            <clear />
            <add name="GoogleMaps" displayName="GoogleMaps-Sample" type="ActiveReports.Samples.CustomTileProviders.GoogleMapsTileProvider, ActiveReports.Samples.CustomTileProviders"/>
          	<add name="OpenStreetMap" displayName="OpenStreetMap-Sample" type="ActiveReports.Samples.CustomTileProviders.OpenStreetMapTileProvider, ActiveReports.Samples.CustomTileProviders"/>          	
            <add name="MapQuest-Sample" displayName="MapQuest-Sample" type="ActiveReports.Samples.CustomTileProviders.MapQuestTileProvider, ActiveReports.Samples.CustomTileProviders">
                <Settings>
                    <add key="ApiKey" value="Fmjtd%7Cluur21ua2l%2C2x%3Do5-90t5h6" />
                    <add key="Timeout" value="3000" />
                </Settings>
            </add>
      </MapTileProviders>
    </ActiveReportsConfig>
    <ActiveReportsConfig.Desktop>
        <ReportWizardReportTypes>
            <clear />
            <add name="Page" />
            <add name="RdlMultiSection" />
        </ReportWizardReportTypes>
        <Settings>
            <add key="Designer.DefaultReportType" value="Page" />
            <add key="Viewer.EnableFontSmoothing" value="false" />
        </Settings>
    </ActiveReportsConfig.Desktop>
</Configuration>
