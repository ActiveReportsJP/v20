<?xml version="1.0" encoding="utf-8" ?>
<Configuration>
    <ActiveReportsConfig>
        <DataProviders>
            <add name="ORACLE"
             type="Oracle.ManagedDataAccess.Client.OracleClientFactory, Oracle.ManagedDataAccess"
             displayName="Oracle Provider" />
            <add name="SQLITE"
             type="System.Data.SQLite.SQLiteFactory, System.Data.SQLite"
             displayName="SQLite Provider" />
            <add name="MYSQL"
             type="MySqlConnector.MySqlConnectorFactory, MySqlConnector"
             displayName="MySQL Provider" />
            <add name="POSTGRESQL"
             type="Npgsql.NpgsqlFactory, Npgsql"
             displayName="PostgreSQL Provider" />
            <add name="EXCEL"
             type="GrapeCity.ActiveReports.Core.DataProviders.Excel.ExcelDataProviderFactory, MESCIUS.ActiveReports.Core.DataProviders.Excel"
             displayName="Excel Provider" />
        </DataProviders>
    </ActiveReportsConfig>
    <ActiveReportsConfig.Desktop>
        <ReportWizardReportTypes>
            <clear />
            <add name="Page" />
            <add name="RdlMultiSection" />
        </ReportWizardReportTypes>	
        <Settings>
            <add key="Designer.DefaultReportType" value="Page" />
            <add key="Viewer.EnableFontSmoothing" value="false" />
        </Settings>
    </ActiveReportsConfig.Desktop>
</Configuration>
