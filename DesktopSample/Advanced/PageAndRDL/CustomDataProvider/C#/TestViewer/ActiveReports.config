<?xml version="1.0" encoding="utf-8" ?>
<Configuration>
    <ActiveReportsConfig>
        <DataProviders>
            <add name="CustomCSV"
             type="ActiveReports.Samples.CustomDataProvider.CSVDataProvider.CsvDataProviderFactory, ActiveReports.Samples.CustomDataProvider"
             displayName="CSV Data Provider"
             commandTextEditorType="ActiveReports.Samples.CustomDataProviderUI.QueryEditor, ActiveReports.Samples.CustomDataProviderUI"/>
        </DataProviders>
        <Settings>
            <add key="ScriptExecutionPolicy" value="Disabled" />
        </Settings>
    </ActiveReportsConfig>
    <ActiveReportsConfig.Desktop>
        <Settings>
            <add key="Viewer.EnableFontSmoothing" value="false" />
        </Settings>
    </ActiveReportsConfig.Desktop>
</Configuration>
